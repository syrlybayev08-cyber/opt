<Page x:Class="SpectrAgency.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔨 ТОВАРЫ" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NameBox" Grid.Column="0" Text="Название" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="CategoryBox" Grid.Column="1" Text="Категория" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="PriceBox" Grid.Column="2" Text="Цена" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="StockBox" Grid.Column="3" Text="Остаток" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="➕ Добавить" Click="AddProduct_Click" Background="#4CAF50" Foreground="White" Padding="10,5" Margin="2"/>
                    <Button Content="✏️ Обновить" Click="UpdateProduct_Click" Background="#FF9800" Foreground="White" Padding="10,5" Margin="2"/>
                    <Button Content="🗑️ Удалить" Click="DeleteProduct_Click" Background="#F44336" Foreground="White" Padding="10,5" Margin="2"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Ручное объявление колонок -->
        <DataGrid x:Name="ProductsGrid" 
                  Grid.Row="2" 
                  AutoGenerateColumns="False"
                  SelectionChanged="ProductsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding category}" Width="120"/>
                <DataGridTextColumn Header="Ед.изм" Binding="{Binding unit}" Width="80"/>
                <DataGridTextColumn Header="Цена, ₽" Binding="{Binding price}" Width="100"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding stock_quantity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>