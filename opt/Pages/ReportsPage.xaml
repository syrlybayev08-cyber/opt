<Page x:Class="SpectrAgency.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Отчёты">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📊 ОТЧЁТЫ" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF5722" CornerRadius="5" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="💰 ВЫРУЧКА" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="RevenueText" Text="0 ₽" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#4CAF50" CornerRadius="5" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="📦 ЗАКАЗОВ" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="OrdersCountText" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#2196F3" CornerRadius="5" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="👥 КЛИЕНТОВ" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="ClientsCountText" Text="0" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🔥 ПОПУЛЯРНЫЕ ТОВАРЫ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <DataGrid x:Name="PopularProductsGrid" AutoGenerateColumns="True" Height="200"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="🔄 Обновить отчёты" Click="RefreshReports_Click" Background="#FF5722" Foreground="White" Padding="10,5" Width="150" HorizontalAlignment="Left" Margin="0,10,0,0"/>
    </Grid>
</Page>