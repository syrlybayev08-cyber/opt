<Page x:Class="SpectrAgency.Pages.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👷 СОТРУДНИКИ" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="#FFF8E1" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FullNameBox" Grid.Column="0" Text="ФИО" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="PositionBox" Grid.Column="1" Text="Должность" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="PhoneBox" Grid.Column="2" Text="Телефон" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <TextBox x:Name="SalaryBox" Grid.Column="3" Text="Зарплата" Margin="0,0,5,0" GotFocus="TextBox_GotFocus"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Content="➕ Добавить" Click="AddEmployee_Click" Background="#4CAF50" Foreground="White" Padding="10,5" Margin="2"/>
                    <Button Content="✏️ Обновить" Click="UpdateEmployee_Click" Background="#FF9800" Foreground="White" Padding="10,5" Margin="2"/>
                    <Button Content="🗑️ Удалить" Click="DeleteEmployee_Click" Background="#F44336" Foreground="White" Padding="10,5" Margin="2"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="EmployeesGrid" 
                  Grid.Row="2" 
                  AutoGenerateColumns="False"
                  SelectionChanged="EmployeesGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding full_name}" Width="200"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding position}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding phone}" Width="120"/>
                <DataGridTextColumn Header="Дата приема" Binding="{Binding hire_date}" Width="100"/>
                <DataGridTextColumn Header="Зарплата, ₽" Binding="{Binding salary}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>